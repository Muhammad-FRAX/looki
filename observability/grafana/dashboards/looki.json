{
  "title": "Looki API",
  "uid": "looki-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(looki_http_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (%)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(looki_http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(looki_http_requests_total[1m])) * 100",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(looki_cache_hits_total[5m]) / (rate(looki_cache_hits_total[5m]) + rate(looki_cache_misses_total[5m]))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Queue Depth",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "looki_queue_depth",
          "legendFormat": "waiting jobs"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Latency (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(looki_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(looki_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(looki_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests by Status Code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(looki_http_requests_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB Pool Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "looki_db_pool_total",
          "legendFormat": "total"
        },
        {
          "expr": "looki_db_pool_idle",
          "legendFormat": "idle"
        },
        {
          "expr": "looki_db_pool_waiting",
          "legendFormat": "waiting"
        }
      ]
    }
  ]
}
